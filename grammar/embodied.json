{
  "location": {
    "template1": "how might your {entity} be embodied?",
    "template2": "must it be {feltVerb}?",
    "slots": {
      "entity": ["location", "position", "movement", "presence"],
      "feltVerb": ["legible", "captured", "named"]
    }
  },
  "stillness": {
    "template1": "what {occurred} in the pause?",
    "template2": "perhaps {possibility} lies dormant there.",
    "slots": {
      "occurred": ["happened", "grew", "bloomed", "whispered"],
      "possibility": ["hope", "a decision", "a memory", "your refusal"]
    }
  },

  "rhythm": {
    "template1": "your name spoken slowly becomes rhythm.",
    "template2": "what beat do you follow?",
    "slots": {}
  },

  "prediction": {
    "template1": "what does the river say about what comes next",
    "template2": "who are you becoming beyond this {projection}?",
    "slots": {
      "projection": ["forecast", "trajectory", "expectation", "assumption"]
    }
  },

  "signal": {
    "template1": "some messages stay close.",
    "template2": "who was this {signal} for?",
    "slots": {
      "signal": ["signal", "message", "call", "transmission"]
    }
  },

    "memory": {
    "template1": "what data does the body refuse to give away?",
    "template2": "where does that {memoryForm} live now?",
    "slots": {
      "memoryForm": ["memory", "story", "history", "information"]
    }
  },

  "identity": {
    "template1": "how are you kept untranslatable?",
    "template2": "who are you beyond this {structure}?",
    "slots": {
      "structure": ["profile", "category", "definition", "pattern"]
    }
  },

  "fallback": {
    "template": "{state} remains unnamed.",
    "slots": {
      "state": ["something", "a presence", "a knowing"]
    }
  }
}